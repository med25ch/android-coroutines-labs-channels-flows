<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CoroutineLab" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#1A1A2E</item>
        <item name="colorPrimaryVariant">#16213E</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#00FF88</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">#1A1A2E</item>
    </style>

    <!-- Full-width lab button -->
    <style name="LabButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="backgroundTint">#1A1A2E</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Smaller button for inline use -->
    <style name="LabButtonSmall" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">#1A1A2E</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">13sp</item>
    </style>

</resources>
