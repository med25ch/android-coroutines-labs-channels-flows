<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📡 Channel Basics"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap each button, observe the output below.\nCheck Logcat for thread/timing details."
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnRendezvous"
        style="@style/LabButton"
        android:text="Ex 1 — Rendezvous (no buffer)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnBuffered"
        style="@style/LabButton"
        android:text="Ex 2 — Buffered (capacity = 3)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnConflated"
        style="@style/LabButton"
        android:text="Ex 3 — Conflated (latest only)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnClose"
        style="@style/LabButton"
        android:text="Ex 4 — Close + for loop"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnClosedSend"
        style="@style/LabButton"
        android:text="Bonus — Send to closed channel"
        android:layout_marginBottom="16dp"/>

    <!-- Output console -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OUTPUT:"
        android:textStyle="bold"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap a button to start...\n"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A1A2E"
            android:textColor="#00FF88"/>
    </ScrollView>

</LinearLayout>
