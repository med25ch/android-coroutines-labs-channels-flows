<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌊 Flow Basics"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cold vs hot, builders, lazy execution, cancellation."
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnCold"
        style="@style/LabButton"
        android:text="Ex 1 — Cold Flow (collect twice)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnFlowOf"
        style="@style/LabButton"
        android:text="Ex 2 — flowOf() and asFlow()"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnLazy"
        style="@style/LabButton"
        android:text="Ex 3 — Lazy (nothing runs before collect)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnCancellation"
        style="@style/LabButton"
        android:text="Ex 4 — Cancellation (auto-cleanup)"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap a button to start...\n"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A1A2E"
            android:textColor="#00FF88"/>
    </ScrollView>

</LinearLayout>
