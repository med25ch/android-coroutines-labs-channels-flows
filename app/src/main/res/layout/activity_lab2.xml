<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔗 produce / Fan-Out / Fan-In"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pipelines and work distribution patterns."
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnProduce"
        style="@style/LabButton"
        android:text="Ex 1 — produce{} builder"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnPipeline"
        style="@style/LabButton"
        android:text="Ex 2 — Pipeline (chain channels)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnFanOut"
        style="@style/LabButton"
        android:text="Ex 3 — Fan-Out (1 producer → 3 workers)"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnFanIn"
        style="@style/LabButton"
        android:text="Ex 4 — Fan-In (3 producers → 1 consumer)"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap a button to start...\n"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A1A2E"
            android:textColor="#00FF88"/>
    </ScrollView>

</LinearLayout>
